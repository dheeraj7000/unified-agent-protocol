{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uap.dev/schemas/provenance.schema.json",
  "title": "UAP Provenance Record",
  "type": "object",
  "required": [
    "task_id",
    "capability_id",
    "actor_id",
    "input_digest",
    "output_digest",
    "trace_id",
    "time"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "capability_id": { "type": "string" },
    "actor_id": { "type": "string" },
    "input_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "output_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "trace_id": { "type": "string" },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false
}
